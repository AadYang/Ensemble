# Template for the real `.env.production` file that deploy.sh generates the
# first time it runs. The real one is gitignored (it carries live secrets).
# Copy this if you need a manual baseline, or just let `bash deploy/deploy.sh`
# generate it for you.

# Telemetry MySQL connection. Required for telemetry endpoints to mount.
ENSEMBLE_MYSQL_HOST=127.0.0.1
ENSEMBLE_MYSQL_PORT=3306
ENSEMBLE_MYSQL_USER=ensemble
ENSEMBLE_MYSQL_PASSWORD=replace-me-with-random-hex-24
ENSEMBLE_MYSQL_DATABASE=ensemble_telemetry

# Bearer token for GET /v1/telemetry/stats. Generate via
#   openssl rand -hex 32
ENSEMBLE_ADMIN_TOKEN=replace-me-with-random-hex-32
