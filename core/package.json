{
  "name": "@ensemble/core",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "dev": "tsx watch --env-file=../.env src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node --env-file=../.env dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "bundle": "node scripts/bundle.mjs",
    "obfuscate": "node scripts/obfuscate.mjs",
    "encrypt-blob": "node scripts/encrypt-blob.mjs",
    "package": "node scripts/bundle.mjs && node scripts/obfuscate.mjs && node scripts/encrypt-blob.mjs && node scripts/make-exe.mjs",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@agentorch/shared": "workspace:*",
    "@anthropic-ai/claude-agent-sdk": "^0.1.10",
    "@fastify/static": "^8.0.0",
    "@fastify/websocket": "^11.0.2",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@openai/agents": "^0.11.0",
    "@openai/codex-sdk": "^0.130.0",
    "fastify": "^5.1.0",
    "js-tiktoken": "^1.0.21",
    "pino-pretty": "^11.3.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "esbuild": "^0.24.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.0",
    "vitest": "^4.1.5"
  }
}
